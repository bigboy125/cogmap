{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cogmap.dev/schemas/intel.schema.json",
  "title": "CogMap INTEL",
  "description": "CogMap 协议主数据结构 — 跨 AI 跨工具的项目记忆数据库",
  "type": "object",
  "required": ["_schema_version", "rules"],
  "properties": {
    "_schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "协议 schema 版本, 当前 v2"
    },
    "rules": {
      "type": "array",
      "description": "项目硬规则, 写代码必须遵守",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "critical": { "type": "boolean", "default": false },
          "applies_to": {
            "type": "array",
            "items": { "type": "string" },
            "description": "适用范围, 如 ['frontend','backend','all']"
          }
        },
        "additionalProperties": true
      }
    },
    "lessons": {
      "type": "object",
      "description": "按节点 ID 索引的经验教训",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "bugs": {
      "type": "object",
      "description": "按节点 ID 索引的 bug 历史",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "types": { "type": "array", "items": { "type": "string" } },
          "count": { "type": "integer", "minimum": 0 },
          "lessons": { "type": "array", "items": { "type": "string" } },
          "fix_pattern": {
            "type": "string",
            "description": "(L3 retry) 修复方式的可复用模板, 模式驱动 retry 命中后会按这个修. 比 lessons 更显式, 是'可执行的修复指令', 不是'反思'."
          }
        },
        "additionalProperties": true
      }
    },
    "iterations": {
      "type": "object",
      "description": "按节点 ID 索引的迭代历史 (实际数据多样, 可能是 array of {date,summary,version}, 也可能是 object 结构, 兼容)",
      "additionalProperties": true
    },
    "guide": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "recipes": {
      "type": "array",
      "items": { "$ref": "#/definitions/recipe" }
    },
    "roadmap": {
      "type": "array",
      "items": { "$ref": "#/definitions/roadmapItem" }
    },
    "session_handoff": {
      "type": "object",
      "description": "会话交接信息, 新对话第一动作必读",
      "additionalProperties": true
    },
    "app_meta": {
      "type": "object",
      "additionalProperties": true
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ts": { "type": "string" },
          "kind": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    },
    "retry_log": {
      "type": "array",
      "description": "(L3 失败自修复) 留痕日志. subagent 失败 → 查 INTEL 命中先例 → 套用修复 → 结果记录在这. 模式驱动 retry 的可视化窗口 — 用户能审 AI 这次为什么这么修.",
      "items": {
        "type": "object",
        "required": ["ts", "failure_signature", "outcome"],
        "properties": {
          "ts": { "type": "string", "description": "ISO8601 时间戳" },
          "failure_signature": {
            "type": "object",
            "description": "失败签名 — 用于以后匹配同类失败",
            "properties": {
              "error_type": { "type": "string", "description": "错误大类, 如 'TypeError' / 'TestFailure' / 'BuildError'" },
              "keywords": {
                "type": "array",
                "items": { "type": "string" },
                "description": "从错误文本提取的关键词, 用于 Jaccard 相似度匹配"
              },
              "raw_excerpt": { "type": "string", "description": "原始错误摘要, ≤200 字" }
            }
          },
          "matched_precedent": {
            "type": ["object", "null"],
            "description": "命中的过去先例. null = 未命中, 必须升级用户",
            "properties": {
              "kind": { "type": "string", "enum": ["bug", "lesson", "retry_log"] },
              "id": { "type": "string", "description": "bug 节点 id 或 lesson topic 或 retry_log 里某条 ts" },
              "fix_pattern": { "type": "string", "description": "命中时套用的修复模板" },
              "score": { "type": "number", "description": "匹配置信度 0-1" }
            }
          },
          "fix_applied": {
            "type": "string",
            "description": "本次实际尝试的修复方式 (可能与 fix_pattern 不完全一致, AI 会做适配)"
          },
          "outcome": {
            "type": "string",
            "enum": ["success", "failure", "escalated"],
            "description": "success=修好了 / failure=改了但还是失败 / escalated=未命中先例直接升级"
          },
          "attempt_n": { "type": "integer", "minimum": 1, "description": "本次失败的第几次重试" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "recipe": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "scenario": { "type": "string" },
        "triggers": { "type": "array", "items": { "type": "string" } },
        "files": { "type": "array", "items": { "type": "string" } },
        "steps": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "unit_tests": { "type": "array", "items": { "type": "string" } },
        "deploy": { "type": "string" },
        "confidence": { "type": "string" },
        "estimatedTime": { "type": "string" },
        "lessons_to_obey": { "type": "array", "items": { "type": "string" } },
        "skill_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "roadmapItem": {
      "type": "object",
      "required": ["id", "title", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]+\\d+$" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "priority": { "type": "string", "enum": ["p0", "p1", "p2", "p3"] },
        "status": {
          "type": "string",
          "enum": ["proposed", "in_progress", "done", "blocked", "rejected"]
        },
        "completed_at": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
