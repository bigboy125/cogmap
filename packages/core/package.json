{
  "name": "cogmap-core",
  "version": "0.1.2",
  "description": "CogMap 协议核心 — INTEL HTTPS 客户端 + JSON Schema + audit/validate 工具",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./map-client": "./src/map-client.mjs",
    "./audit": "./src/audit.mjs",
    "./validate": "./src/validate.mjs",
    "./match-recipe": "./src/match-recipe.mjs",
    "./check-bug-history": "./src/check-bug-history.mjs",
    "./match-failure-precedent": "./src/match-failure-precedent.mjs",
    "./log-retry": "./src/log-retry.mjs",
    "./lesson-utils": "./src/lesson-utils.mjs",
    "./schemas/intel": "./schemas/intel.schema.json"
  },
  "files": [
    "src",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/"
  },
  "keywords": [
    "cogmap",
    "intel",
    "ai-memory",
    "claude",
    "json-schema"
  ],
  "author": "bigboy125",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigboy125/cogmap.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "release-it": {
    "git": {
      "tagName": "core-v${version}",
      "commitMessage": "release: cogmap-core@${version}",
      "tagAnnotation": "cogmap-core ${version}",
      "requireCleanWorkingDir": true,
      "push": true
    },
    "npm": { "publish": false },
    "github": { "release": false },
    "hooks": {
      "before:init": ["cd ../.. && npm test"]
    }
  }
}
